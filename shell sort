#include <stdio.h>
#include <stdlib.h>

// Function to perform Shell Sort (using better gap sequence)
void shellSort(int arr[], int n) {
    int gap, i, j, temp;

    // Using Knuth sequence: gap = gap*3 + 1
    for (gap = 1; gap < n / 3; gap = 3 * gap + 1);

    for (; gap > 0; gap /= 3) {
        for (i = gap; i < n; i++) {
            temp = arr[i];

            for (j = i; j >= gap && arr[j - gap] > temp; j -= gap) {
                arr[j] = arr[j - gap];
            }

            arr[j] = temp;
        }
    }
}

